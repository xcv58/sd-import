<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Reference template only. launchd requires absolute paths and does not expand $HOME. -->
  <key>Label</key>
  <string>com.xcv58.sd-import</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/Users/YOUR_USER/work/sd-import/sd_import.py</string>
    <string>auto</string>
    <string>--notify</string>
  </array>

  <key>StartOnMount</key>
  <true/>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/Users/YOUR_USER/.sd-import/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/YOUR_USER/.sd-import/launchd.err.log</string>
</dict>
</plist>
