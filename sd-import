#!/bin/bash
set -euo pipefail

# Resolve symlinks so ~/.local/bin/sd-import can locate files in the repo.
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  if [[ "$LINK_TARGET" == /* ]]; then
    SCRIPT_PATH="$LINK_TARGET"
  else
    SCRIPT_PATH="$SCRIPT_DIR/$LINK_TARGET"
  fi
done

ROOT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
PY=/usr/bin/python3
CORE="$ROOT_DIR/sd_import.py"

usage() {
  cat <<'EOF'
Usage:
  sd-import auto [LOCATION]
  sd-import retry-latest
  sd-import status [--job-id JOB_ID] [--follow] [--json]
  sd-import list-mounts [--json]
  sd-import list-jobs [LIMIT|--limit N|--json]
  sd-import prune [--days N] [--dry-run] [--vacuum]
  sd-import <any sd_import.py args>

Examples:
  sd-import auto NYC
  sd-import status --follow
  sd-import retry-latest
  sd-import list-mounts --json
  sd-import prune --days 180 --vacuum
  sd-import run --input /Volumes/SDCARD --location NYC --notify
EOF
}

latest_job_id() {
  "$PY" - <<'PY'
import sqlite3
from pathlib import Path
p = Path.home()/'.sd-import'/'state.db'
if not p.exists():
    print("")
    raise SystemExit(0)
conn = sqlite3.connect(p)
row = conn.execute("SELECT job_id FROM jobs ORDER BY created_at DESC LIMIT 1").fetchone()
print(row[0] if row else "")
PY
}

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

case "$1" in
  auto)
    shift
    if [[ $# -eq 0 ]]; then
      "$PY" "$CORE" auto --notify
    elif [[ "${1:-}" == -* ]]; then
      "$PY" "$CORE" auto "$@"
    else
      LOCATION="$1"
      shift
      "$PY" "$CORE" auto --location "$LOCATION" "$@"
    fi
    ;;
  retry-latest)
    JOB_ID="$(latest_job_id)"
    if [[ -z "$JOB_ID" ]]; then
      echo "No jobs found"
      exit 1
    fi
    "$PY" "$CORE" retry --job-id "$JOB_ID"
    ;;
  list-jobs)
    shift
    if [[ $# -eq 0 ]]; then
      "$PY" "$CORE" list-jobs --limit 15
    else
      "$PY" "$CORE" list-jobs "$@"
    fi
    ;;
  list-mounts)
    shift
    "$PY" "$CORE" list-mounts "$@"
    ;;
  status)
    shift
    "$PY" "$CORE" status "$@"
    ;;
  prune)
    shift
    "$PY" "$CORE" prune "$@"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    "$PY" "$CORE" "$@"
    ;;
esac
